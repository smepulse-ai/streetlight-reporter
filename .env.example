# Copy this file to .env.local and fill in your own values
# Never commit .env.local to git

# Supabase — find these in your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Maps — create a key at console.cloud.google.com
# Restrict it to your deployed domain under API restrictions > HTTP referrers
VITE_GMAP_KEY=your-google-maps-api-key
